PORT=5000
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=3306
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Zoho OAuth & APIs
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CRM_API_URL=https://www.zohoapis.com/crm/v3
ZOHO_SIGN_API_URL=https://sign.zoho.com/api/v1
ZOHO_SIGN_TEMPLATE_ID=your_zoho_sign_template_id_here

# Zoho ZeptoMail Credentials
ZEPTOMAIL_TOKEN=your_zeptomail_token_here
ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_FROM_ADDRESS=noreply@yourdomain.com
ZEPTOMAIL_FROM_NAME=TLU Food
